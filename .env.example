# Runtime
NODE_ENV=development
HOST=localhost
PORT=3000
CORS_ORIGIN=http://localhost:4200

# PostgreSQL / Prisma
# DIRECT_URL is required because it is declared as shadowDatabaseUrl in schema.prisma.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/spark_nexus_ed?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/spark_nexus_ed_shadow?schema=public

# Auth0 backend API validation
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.spark-nexus-ed.local

# Reserved for server-side Auth0 flows; not required by the current bootstrap path.
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_CALLBACK_URL=http://localhost:3000/api/v1/auth/callback

# Auth0 frontend SPA
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=https://api.spark-nexus-ed.local
VITE_AUTH0_CALLBACK_URL=http://localhost:4200/callback

# Frontend service endpoints
VITE_REACT_APP_API_URL=http://localhost:3000/api/v1
VITE_WS_URL=ws://localhost:3000
VITE_REACT_APP_VERSION=local

# Redis / BullMQ
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USER=
REDIS_PASSWORD=
REDIS_TLS=false
REDIS_TLS_REJECT_UNAUTHORIZED=true
REDIS_TLS_SERVERNAME=

# Nx diagnostics
NX_VERBOSE_LOGGING=false
