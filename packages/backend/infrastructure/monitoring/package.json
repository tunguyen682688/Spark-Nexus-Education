{
  "name": "@spark-nest-ed/infrastructure-monitoring",
  "version": "0.0.1",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@spark-nest-ed/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "nx": {
    "name": "infrastructure-monitoring",
    "tags": [
      "backend"
    ],
    "targets": {
      "build": {
        "executor": "@nx/js:tsc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "dist/packages/backend/infrastructure/monitoring",
          "tsConfig": "packages/backend/infrastructure/monitoring/tsconfig.lib.json",
          "packageJson": "packages/backend/infrastructure/monitoring/package.json",
          "main": "packages/backend/infrastructure/monitoring/src/index.ts",
          "assets": [
            "packages/backend/infrastructure/monitoring/*.md"
          ]
        }
      }
    }
  },
  "dependencies": {
    "tslib": "^2.3.0"
  }
}
