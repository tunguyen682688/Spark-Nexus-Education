{
  "name": "@spark-nest-ed/infrastructure-database",
  "version": "0.0.1",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@spark-nest-ed/source": "./src/index.ts",
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "nx": {
    "name": "infrastructure-database",
    "targets": {
      "build": {
        "executor": "@nx/js:tsc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "dist/packages/backend/infrastructure/database",
          "tsConfig": "packages/backend/infrastructure/database/tsconfig.lib.json",
          "packageJson": "packages/backend/infrastructure/database/package.json",
          "main": "packages/backend/infrastructure/database/src/index.ts",
          "assets": [
            "packages/backend/infrastructure/database/*.md"
          ]
        }
      },
      "lint": {
        "executor": "@nx/eslint:lint",
        "outputs": [
          "{options.outputFile}"
        ],
        "options": {
          "lintFilePatterns": [
            "packages/backend/infrastructure/database/**/*.ts"
          ]
        }
      },
      "test": {
        "executor": "@nx/jest:jest",
        "outputs": [
          "{workspaceRoot}/coverage/{projectRoot}"
        ],
        "options": {
          "jestConfig": "packages/backend/infrastructure/database/jest.config.ts"
        }
      },
      "prisma-generate": {
        "executor": "nx:run-commands",
        "outputs": [
          "{projectRoot}/node_modules/.prisma"
        ],
        "options": {
          "command": "prisma generate",
          "cwd": "packages/backend/infrastructure/database"
        }
      },
      "prisma-migrate": {
        "executor": "nx:run-commands",
        "options": {
          "command": "prisma migrate dev",
          "cwd": "packages/backend/infrastructure/database"
        }
      },
      "prisma-migrate-deploy": {
        "executor": "nx:run-commands",
        "options": {
          "command": "prisma migrate deploy",
          "cwd": "packages/backend/infrastructure/database"
        }
      },
      "prisma-studio": {
        "executor": "nx:run-commands",
        "options": {
          "command": "prisma studio",
          "cwd": "packages/backend/infrastructure/database"
        }
      },
      "prisma-push": {
        "executor": "nx:run-commands",
        "options": {
          "command": "prisma db push",
          "cwd": "packages/backend/infrastructure/database"
        }
      },
      "prisma-seed": {
        "executor": "nx:run-commands",
        "options": {
          "command": "prisma db seed",
          "cwd": "packages/backend/infrastructure/database"
        },
        "dependsOn": [
          "prisma-generate"
        ]
      },
      "prisma-reset": {
        "executor": "nx:run-commands",
        "options": {
          "command": "prisma migrate reset --force",
          "cwd": "packages/backend/infrastructure/database"
        }
      }
    }
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "tslib": "^2.3.0",
    "@nestjs/common": "^11.0.0",
    "@prisma/client": "^6.19.0",
    "rxjs": "^7.8.0"
  }
}
