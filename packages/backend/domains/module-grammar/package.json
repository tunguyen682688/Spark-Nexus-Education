{
  "name": "@spark-nest-ed/module-grammar",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.js",
  "module": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@spark-nest-ed/source": "./src/index.ts",
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    }
  },
  "nx": {
    "name": "module-grammar",
    "tags": [
      "backend"
    ],
    "targets": {
      "build": {
        "executor": "@nx/js:tsc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "dist/packages/backend/domains/module-grammar",
          "tsConfig": "packages/backend/domains/module-grammar/tsconfig.lib.json",
          "packageJson": "packages/backend/domains/module-grammar/package.json",
          "main": "packages/backend/domains/module-grammar/src/index.ts"
        }
      }
    }
  },
  "dependencies": {
    "tslib": "^2.3.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@spark-nest-ed/infrastructure-database": "0.0.1",
    "@spark-nest-ed/infrastructure-auth": "0.0.1",
    "@prisma/client": "^6.19.0",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/swagger": "^11.2.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "uuid": "11.1.0",
    "@spark-nest-ed/shared-libs": "0.0.1",
    "express": "^5.0.0"
  }
}
