{
  "name": "@spark-nest-ed/api-sne",
  "version": "0.0.1",
  "description": "Spark Nexus Ed Backend API - NestJS application for the learning platform",
  "private": true,
  "license": "MIT",
  "author": "Spark Nexus Ed Team",
  "main": "dist/main.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "nx": {
    "name": "api-sne",
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "command": "webpack-cli build",
          "args": ["--node-env=production"],
          "cwd": "apps/api-sne"
        },
        "configurations": {
          "development": {
            "args": ["--node-env=development"]
          },
          "production": {
            "args": ["--node-env=production"]
          }
        },
        "outputs": ["{projectRoot}/dist"]
      },
      "serve": {
        "continuous": true,
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "options": {
          "buildTarget": "api-sne:build",
          "runBuildTargetDependencies": true,
          "watch": true
        },
        "configurations": {
          "development": {
            "buildTarget": "api-sne:build:development"
          },
          "production": {
            "buildTarget": "api-sne:build:production"
          }
        }
      },
      "dev": {
        "continuous": true,
        "executor": "nx:run-commands",
        "options": {
          "commands": [
            "nx build api-sne --configuration=development",
            "nx run-node api-sne"
          ],
          "parallel": false
        }
      },
      "run-node": {
        "continuous": true,
        "executor": "@nx/js:node",
        "options": {
          "buildTarget": "api-sne:build:development",
          "runBuildTargetDependencies": false,
          "watch": false
        }
      },
      "start:only": {
        "continuous": true,
        "executor": "nx:run-commands",
        "options": {
          "command": "node dist/main.js",
          "cwd": "apps/api-sne"
        },
        "configurations": {
          "development": {
            "args": []
          },
          "production": {
            "args": []
          }
        }
      },
      "lint": {
        "executor": "@nx/eslint:lint",
        "options": {
          "lintFilePatterns": ["apps/api-sne/**/*.ts"]
        }
      },
      "test": {
        "executor": "@nx/jest:jest",
        "options": {
          "jestConfig": "apps/api-sne/jest.config.cts",
          "passWithNoTests": true
        }
      },
      "prune-lockfile": {
        "dependsOn": ["build"],
        "cache": true,
        "executor": "@nx/js:prune-lockfile",
        "outputs": [
          "{workspaceRoot}/apps/api-sne/dist/package.json",
          "{workspaceRoot}/apps/api-sne/dist/package-lock.json"
        ],
        "options": {
          "buildTarget": "build"
        }
      },
      "copy-workspace-modules": {
        "dependsOn": ["build"],
        "cache": true,
        "outputs": ["{workspaceRoot}/apps/api-sne/dist/workspace_modules"],
        "executor": "@nx/js:copy-workspace-modules",
        "options": {
          "buildTarget": "build"
        }
      },
      "prune": {
        "dependsOn": ["prune-lockfile", "copy-workspace-modules"],
        "executor": "nx:noop"
      }
    },
    "tags": ["scope:backend", "type:app"],
    "implicitDependencies": [
      "module-vocabulary",
      "module-grammar",
      "module-reading",
      "infrastructure-auth",
      "infrastructure-database",
      "shared-libs"
    ]
  },
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "nx serve api-sne",
    "start:only": "nx start:only api-sne",
    "start:prod": "NODE_ENV=production node dist/main.js",
    "dev": "nx dev api-sne",
    "build": "nx build api-sne",
    "build:dev": "nx build api-sne --configuration=development",
    "build:prod": "nx build api-sne --configuration=production",
    "lint": "nx lint api-sne",
    "test": "nx test api-sne",
    "test:watch": "nx test api-sne --watch",
    "test:cov": "nx test api-sne --coverage"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.0",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.2.1",
    "@prisma/client": "^6.19.0",
    "bullmq": "^5.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/passport-jwt": "^4.0.1"
  }
}
